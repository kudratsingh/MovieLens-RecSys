# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
*.so
.venv/
venv/
env/

# ML artifacts
mlruns/
mlartifacts/
*.pkl
*.joblib
*.pt
*.onnx
# Anchored to repo root so we don't accidentally ignore `src/models/`
# (the source tree for model classes). Future trained-model dumps go in /models/.
/models/

# DVC: ignore the data dirs' contents but keep the DVC pointer files
# and the per-directory .gitignore files that `dvc add` manages.
# Without the un-ignores, the blanket /data/raw/ pattern would hide the
# very .dvc refs git needs to track.
/data/raw/*
/data/processed/*
!/data/raw/.gitignore
!/data/raw/*.dvc
!/data/processed/.gitignore
!/data/processed/*.dvc
.dvc/cache/
.dvc/tmp/

# Env / secrets
.env
.env.*
*.env

# Jupyter
.ipynb_checkpoints/
*.ipynb

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp

# Logs
*.log
logs/

# Docker
*.override.yml
